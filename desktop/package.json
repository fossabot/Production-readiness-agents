{
  "name": "production-readiness-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prepackage": "node scripts/prepare-runtime-assets.mjs",
    "package": "npm run prepackage && electron-builder",
    "package:win": "npm run prepackage && electron-builder --win",
    "package:mac": "npm run prepackage && electron-builder --mac",
    "package:linux": "npm run prepackage && electron-builder --linux",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test",
    "verify:all": "npm run verify && npm run build && npm run release:assets --check-only",
    "release:gate": "node scripts/release-gate.mjs",
    "release:smoke": "node scripts/smoke-validate.mjs",
    "release:assets": "node scripts/prepare-runtime-assets.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-vite": "^5.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0"
  }
}
